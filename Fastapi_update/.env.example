JWT_SECRET_KEY=replace_me_with_a_long_random_secret                                  # Khóa ký JWT
JWT_EXPIRE_MINUTES=120                                                               # Thời gian sống của token
REDIS_URL=redis://127.0.0.1:6379/0                                                   # Đường dẫn kết nối tới Redis để dùng Queue, retry, DLQ, stream
DATABASE_URL=postgresql+asyncpg://demo_user:demo_pass@127.0.0.1:5432/realtime_demo   # Đường dẫn kết nối DB
QUEUE_KEY=prod_demo:queue:main                                                       # Key Redis list của Queue chính
RETRY_ZSET_KEY=prod_demo:queue:retry                                                 # Key Redis sorted set cho retry delayed
DLQ_KEY=prod_demo:queue:dlq                                                          # Key Redis list cho dead-letter queue
STREAM_PREFIX=prod_demo:stream                                                       # Prefix của Redis Stream
JOB_STATUS_KEY_PREFIX=prod_demo:job
JOB_STATUS_TTL_SECONDS=604800                                      
STREAM_MAXLEN_USER=5000                                                              # Retention theo số lượng event
STREAM_MAXLEN_TENANT=10000                                                           # Retention theo số lượng event
MAX_UPLOAD_BYTES=10485760                                                            # Giới hạn dung lượng upload
MAX_RETRY_ATTEMPTS=3                                                                 # Retry policy
RETRY_BASE_SECONDS=5                                                                 # Retry policy
OBJECT_STORAGE_BACKEND=local                                                         # Nơi lưu trữ là local hoặc s3
LOCAL_OBJECT_STORAGE_DIR=./storage/local_objects                                     # Thư mục lưu trữ nếu chạy local
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
API_BASE_URL=http://127.0.0.1:8000                                                   # Địa chỉ API để client gọi API
NOTIFICATION_BASE_URL=ws://127.0.0.1:8001                                            # Địa chỉ API để client gọi websocket
